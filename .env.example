# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_approval
DB_SSL=false

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-longa-em-producao

# ─── Cloudflare R2 Storage ──────────────────────────────
CF_ACCOUNT_ID=seu-account-id
CF_R2_ACCESS_KEY_ID=seu-access-key-id
CF_R2_SECRET_ACCESS_KEY=seu-secret-access-key
CF_R2_BUCKET=videos-approval
CF_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Backend ────────────────────────────────────────────
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000,https://seu-dominio.com

# ─── N8N Webhooks (opcional) ────────────────────────────
N8N_WEBHOOK_APROVADO=https://seu-n8n.com/webhook/video-aprovado
N8N_WEBHOOK_REPROVADO=https://seu-n8n.com/webhook/video-reprovado

# ─── Frontend ───────────────────────────────────────────
# Em produção, use a URL pública do backend (ex: https://api.seu-dominio.com)
NEXT_PUBLIC_API_URL=http://localhost:3001
